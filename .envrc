project_root="$(pwd -P)"
project_name="${project_root##*/}"
project_slug="$(printf '%s' "$project_name" | tr -c 'A-Za-z0-9._-' '_')"
project_hash="$(printf '%s' "$project_root" | sha256sum | cut -c1-12)"

direnv_layout_dir="${XDG_CACHE_HOME:-$HOME/.cache}/direnv/layouts/${project_slug}-${project_hash}"

use flake

export UV_PROJECT_ENVIRONMENT="${XDG_DATA_HOME:-$HOME/.local/share}/uv/project-envs/${project_slug}-${project_hash}"

if [ -f "$UV_PROJECT_ENVIRONMENT/bin/activate" ]; then
  source "$UV_PROJECT_ENVIRONMENT/bin/activate"
fi
